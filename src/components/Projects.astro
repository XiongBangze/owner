---
interface Props {
  title: string;
  items: { name: string; tech: string[]; description: string }[];
}
const { title, items } = Astro.props;
---
<section class="py-12">
  <h2 class="mb-8 text-2xl font-bold text-primary">{title}</h2>
  <div class="grid gap-6 md:grid-cols-2">
    {items.map(item => (
      <div class="rounded-xl border border-border bg-surface-light p-6">
        <h3 class="text-lg font-semibold">{item.name}</h3>
        <p class="mt-2 text-sm text-text-muted">{item.description}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {item.tech.map(t => <span class="rounded-full bg-primary/10 px-3 py-1 text-xs text-primary">{t}</span>)}
        </div>
      </div>
    ))}
  </div>
</section>
