---
interface Props {
  title: string;
  items: { company: string; position: string; location?: string; period: string; description: string[] }[];
}
const { title, items } = Astro.props;
---
<section class="py-12">
  <h2 class="mb-8 text-2xl font-bold text-primary">{title}</h2>
  <div class="space-y-8">
    {items.map(item => (
      <div class="rounded-xl border border-border bg-surface-light p-6">
        <div class="flex flex-wrap items-baseline justify-between gap-2">
          <h3 class="text-lg font-semibold">{item.position}</h3>
          <span class="text-sm text-text-muted">{item.period}</span>
        </div>
        <p class="mt-1 text-sm text-primary">{item.company}{item.location && ` · ${item.location}`}</p>
        <ul class="mt-3 space-y-1 text-text-muted text-sm">
          {item.description.map(d => <li class="before:mr-2 before:text-primary before:content-['▹']">{d}</li>)}
        </ul>
      </div>
    ))}
  </div>
</section>
