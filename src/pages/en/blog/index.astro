---
import Base from '../../../layouts/Base.astro';
import { t } from '../../../i18n';
import { getCollection } from 'astro:content';

const lang = 'en' as const;
const i = t(lang);
const posts = (await getCollection('blog', ({ id }) => id.startsWith('en/'))).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---
<Base lang={lang} title={`${i.section.blog} | Bangze Xiong`}>
  <section class="py-12">
    <h1 class="mb-8 text-3xl font-bold text-primary">{i.section.blog}</h1>
    {posts.length === 0 && <p class="text-text-muted">{i.blog.empty}</p>}
    <div class="space-y-6">
      {posts.map(post => (
        <a href={`/${lang}/blog/${post.id.replace('en/', '')}/`} class="block rounded-xl border border-border bg-surface-light p-6 hover:border-primary transition-colors">
          <h2 class="text-lg font-semibold">{post.data.title}</h2>
          <p class="mt-1 text-sm text-text-muted">{post.data.date} · {post.data.tags?.join(', ')}</p>
          {post.data.description && <p class="mt-2 text-sm text-text-muted">{post.data.description}</p>}
        </a>
      ))}
    </div>
  </section>
</Base>
