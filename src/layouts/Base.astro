---
import '../styles/global.css';
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  lang: Lang;
}

const { title = '熊邦泽 | 服务端开发工程师', description = '个人简历与知识库', lang } = Astro.props;
const i = t(lang);
---
<!DOCTYPE html>
<html lang={lang} class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body class="min-h-screen font-sans antialiased">
  <!-- Nav -->
  <nav class="fixed top-0 z-50 w-full border-b border-border bg-surface/80 backdrop-blur-md">
    <div class="mx-auto flex max-w-4xl items-center justify-between px-6 py-3">
      <a href={`/${lang}/`} class="text-lg font-bold text-primary">{lang === 'zh' ? '熊邦泽' : 'Bangze Xiong'}</a>
      <div class="flex items-center gap-4 text-sm">
        <a href={`/${lang}/`} class="text-text-muted hover:text-primary transition-colors">{i.nav.home}</a>
        <a href={`/${lang}/blog/`} class="text-text-muted hover:text-primary transition-colors">{i.nav.blog}</a>
        <a href={`/${lang === 'zh' ? 'en' : 'zh'}/`} class="rounded border border-border px-2 py-1 text-text-muted hover:text-primary transition-colors">{i.nav.language}</a>
        <button id="theme-toggle" class="rounded border border-border px-2 py-1 text-text-muted hover:text-primary transition-colors" aria-label="Toggle theme">🌙</button>
      </div>
    </div>
  </nav>

  <!-- Content -->
  <main class="mx-auto max-w-4xl px-6 pt-20 pb-16">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-border py-6 text-center text-sm text-text-muted">
    {i.footer.builtWith} · © {new Date().getFullYear()}
  </footer>

  <!-- Theme toggle script -->
  <script is:inline>
    const html = document.documentElement;
    const btn = document.getElementById('theme-toggle');
    const saved = localStorage.getItem('theme');
    if (saved === 'light') { html.classList.remove('dark'); html.classList.add('light'); }
    if (btn) btn.textContent = html.classList.contains('light') ? '🌙' : '☀️';
    btn?.addEventListener('click', () => {
      const isLight = html.classList.toggle('light');
      html.classList.toggle('dark');
      localStorage.setItem('theme', isLight ? 'light' : 'dark');
      btn.textContent = isLight ? '🌙' : '☀️';
    });
  </script>
</body>
</html>
